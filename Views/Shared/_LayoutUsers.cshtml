    <script type="text/javascript">

        $(document).ready(function () {
            $.ajax({
                url: '/User/CheckAuthentication',
                success: function (response) {
                    console.log(response);

                    if (response.isAuthenticated) {
                        const avatarUrl = "/images/customer/" + response.avatar;

       
                        $('.in_login').remove();
                        if (response.iscustomer) {

     
                            $('.wrap_login').html(`
                                            <li class="has-children">
                                                <img class="avatar_img" src="${avatarUrl}" alt="Candidate Avatar"></img>
                                                <ul class="profileavatar">
                                                    <li><a href="/User/Profile">Profile</a></li>
                                                    <li><a class="logout" href="#">Logout</a></li>
                                                </ul>
                                            </li>
                                            `);
                        }


                        // Bắt sự kiện logout
                        $('.logout').click(function (e) {
                            e.preventDefault();
                            $.ajax({
                                url: '/User/Logout',
                                method: 'POST',
                                success: function () {
                                    // Chuyển hướng sau khi đăng xuất thành công
                                    window.location.href = '/';
                                },
                                error: function () {
                                    alert('An error occurred during logout.');
                                }
                            });
                        });
                    }
                },
                error: function () {
                    console.error('Failed to check authentication.');
                }
            });
        });
        // Mở modal
        function openModal() {
            document.getElementById("myModal").style.display = "block";
        }

        // Đóng modal
        function closeModal() {
            document.getElementById("myModal").style.display = "none";
        }

        // Đóng modal khi nhấn ra ngoài modal
        window.onclick = function (event) {
            var modal = document.getElementById("myModal");
            if (event.target == modal) {
                modal.style.display = "none";
            }
        }
        function showFileName() {
            // Lấy đối tượng input file
            var input = document.getElementById('fileselect');
            // Lấy tên file
            var fileName = input.files[0].name;
        }
        function toggleChat() {
            const chatWindow = document.querySelector('.chat-window');
            const chatIcon = document.querySelector('.chat-icon');
            const facebookIcon = document.querySelector('.facebook-icon');
            const zaloIcon = document.querySelector('.zalo-icon');
            chatWindow.style.display = chatWindow.style.display === 'block' ? 'none' : 'block';
            chatWindow.classList.toggle('show'); // Toggles visibility of chat window

            // Stop shaking icon if chat is open
            if (chatWindow.classList.contains('show')) {
                chatIcon.classList.remove('shake');
            } else {
                chatIcon.classList.add('shake');
                facebookIcon.classList.add('shake');
                zaloIcon.classList.add('shake');
            }
        }
        document.addEventListener('DOMContentLoaded', () => {
            const icons = document.querySelectorAll(' .facebook-icon, .zalo-icon');
            icons.forEach(icon => icon.classList.add('shake'));
        });
        function openZalo() {
            window.open("https://zalo.me", "_blank");
        }

        function openFacebook() {
            window.open("https://www.facebook.com", "_blank");
        }


        // Function to handle sending a message
        function sendMessage() {
            const inputField = document.querySelector('.chat-input input');
            const message = inputField.value.trim();

            if (message) {
                addMessage("user-message", message); // Add user's message to the chat
                botResponse(message); // Generate bot's response based on user's message
                inputField.value = ""; // Clear input field after sending
            }
        }

        // Event listener for the "Gửi" button
        document.querySelector('.send-button').addEventListener('click', sendMessage);

        // Event listener for the "Enter" key
        document.querySelector('.chat-input input').addEventListener('keypress', function (event) {
            if (event.key === "Enter") {
                sendMessage(); // Trigger sendMessage function when Enter is pressed
            }
        });


        function addMessage(className, text) {
            const chatBody = document.querySelector(".chat-body");
            const messageDiv = document.createElement("div");
            messageDiv.className = className;
            messageDiv.textContent = text;
            chatBody.appendChild(messageDiv);
            chatBody.scrollTop = chatBody.scrollHeight; // Scroll to the latest message
        }

        function botResponse(message) {
            let response;

            // Convert the message to lowercase to make keyword checks case-insensitive
            const lowerMessage = message.toLowerCase();

            // Check for keywords
            if (lowerMessage.includes("chào") || lowerMessage.includes("xin chào") || lowerMessage.includes("helo") || lowerMessage.includes("helo shop ")) {
                response = "Shop phụ kiện thú cưng hân hạnh chào bạn, mời bạn ghé thăm shop và lựa món đồ yêu thích ạ!";
            } else if (lowerMessage.includes("còn") || lowerMessage.includes("ưu đãi")) {
                response = "Xin đợi chờ trong giây lát, shop sẽ phản hồi lại trong giây lát.";
            } else if (lowerMessage.includes("địa điểm")) {
                response = "Shop ở Việt Nam.";
            }
            else if (lowerMessage.includes("Biết bạn hiếu là ai không ?") || lowerMessage.includes("biết")) {
                response = "Bạn hiếu giàu nhất việt nam.";
            } else if (lowerMessage.includes("mua") || lowerMessage.includes("hàng")) {
                response = "Bạn hãy vào shop lựa món đồ yêu thích và thanh toán trực tiếp hoặc gián tiếp.";
            } else {
                response = "Xin lỗi, tôi chưa hiểu câu hỏi của bạn. Bạn có thể hỏi về thêm mặt hàng shop bán , địa điểm ở đâu , hoặc cách mua hàng.";
            }




            addMessage("bot-message", response);
        }



    </script>
</body>

</html>